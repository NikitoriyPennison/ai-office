{
  "name": "ai-office-constructor",
  "version": "1.0.0",
  "description": "Конструктор AI Office — визуальный офис для ваших AI агентов",
  "private": true,
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev": "next dev -p 3100",
    "build": "NODE_OPTIONS='--max-old-space-size=512' next build",
    "start": "next start -p 3100",
    "sync": "node scripts/sync-agents.js",
    "deploy": "bash scripts/deploy.sh",
    "install-sync": "bash scripts/install-sync.sh",
    "db:migrate": "tsx src/lib/db/migrate.ts",
    "seed": "node scripts/seed.js"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.38.4",
    "jsonwebtoken": "^9.0.2",
    "next": "^15.1.0",
    "pixi.js": "8.6.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "twilio": "^5.13.1",
    "uuid": "^11.0.5",
    "ws": "^8.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
