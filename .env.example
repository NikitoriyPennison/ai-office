# AI Office Environment Variables
# Copy to .env and fill in values

# JWT Secret — ОБЯЗАТЕЛЬНО замени! Сгенерируй: openssl rand -hex 32
JWT_SECRET=change-me-to-random-secret

# Database path (default: ./data/database.sqlite)
# DATABASE_URL=./data/database.sqlite

# Node environment
NODE_ENV=production

# WebSocket allowed origins (comma-separated). Empty = allow all (dev mode)
# ALLOWED_ORIGINS=https://office.example.com,http://localhost:3100

# OpenClaw home directory (default: ~/.openclaw)
# OPENCLAW_HOME=~/.openclaw

# GenAI Pro API key (для TTS, опционально)
# GENAIPRO_API_KEY=your-key

# Telegram Bot Token (получить у @BotFather)
TELEGRAM_TOKEN=your-telegram-bot-token

# Discord Bot Tokens (если используешь Discord)
# DISCORD_TOKEN_STIK=your-discord-token
# DISCORD_TOKEN_DEV=your-discord-dev-token

# OpenAI + Groq (для LLM)
# OPENAI_API_KEY=your-openai-key
# GROQ_API_KEY=your-groq-key
